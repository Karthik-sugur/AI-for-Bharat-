# LandLedger Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=LandLedger
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ============================================================================
# AWS Configuration
# Get these from AWS IAM Console
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ============================================================================
# Amazon Bedrock (AI)
# Using Claude 3 Sonnet for legal analysis
# ============================================================================
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4000

# ============================================================================
# Amazon S3 (Document Storage)
# Bucket will be created automatically if it doesn't exist
# ============================================================================
S3_BUCKET_NAME=landledger-documents
S3_PRESIGNED_URL_EXPIRY=86400

# ============================================================================
# Amazon DynamoDB (Caching)
# Table will be created automatically if it doesn't exist
# ============================================================================
DYNAMODB_TABLE_NAME=landledger-cache
DYNAMODB_TTL_HOURS=24

# ============================================================================
# Amazon Polly (Text-to-Speech)
# ============================================================================
POLLY_VOICE_ENGLISH=Joanna
POLLY_VOICE_HINDI=Aditi
POLLY_OUTPUT_FORMAT=mp3

# ============================================================================
# API Configuration
# ============================================================================
API_PREFIX=/api
# Comma-separated list of allowed origins (use * for development)
CORS_ORIGINS=*

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
